{"_id":"SimulacrumRollD","name":"Roll Dice","type":"script","author":"SimulacrumAI","img":"icons/sundries/gaming/dice-pair-white-blue.webp","scope":"global","command":"/**\n * Roll Dice\n * \n * Arg: formula (string) e.g. \"1d20 + 5\"\n */\nconst formula = scope.args?.formula || \"1d20\";\nconst r = new Roll(formula);\nawait r.evaluate();\n\n// Show in chat so user sees it too\nawait r.toMessage({\n  flavor: `AI requested roll: ${formula}`\n});\n\n// Return the total and the broken down result for the AI\nreturn {\n  formula: r.formula,\n  total: r.total,\n  result: r.result\n};","folder":null,"sort":0,"permission":{"default":0},"flags":{}}
