{"_id":"SimulacrumExampl","name":"Roll Dice","type":"script","author":"SimulacrumAIUser","img":"icons/sundries/gaming/dice-pair-white-blue.webp","scope":"global","command":"/**\n * Roll Dice\n * \n * Arg: formula (string) e.g. \"1d20 + 5\"\n */\nconst formula = scope.args?.formula || \"1d20\";\nconst r = new Roll(formula);\nawait r.evaluate();\n\n// Return minimal data to avoiding flooding AI context with Roll object internals\nreturn {\n  formula: r.formula,\n  total: r.total,\n  result_string: r.result // In some Foundry versions this is a string, if not we ensure it is safe\n};","folder":null,"sort":0,"permission":{"default":0},"flags":{}}
