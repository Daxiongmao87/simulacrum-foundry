{
  "schema_version": "v1",
  "project": {
    "key": "simulacrum",
    "display_name": "Simulacrum: AI Campaign Copilot",
    "base_branch": "main"
  },
  "pipeline": {
    "trigger_labels": ["agent"],
    "human_authority": "Daxiongmao87",
    "models": {
      "default": "gpt-5.4",
      "roles": []
    },
    "protected_paths": [
      ".github/workflows",
      "CHANGELOG.md",
      "module.json",
      ".agentic-delivery/project.json",
      "tests/unit/ui-tier-tagging.test.mjs",
      "tools/test-tier-runner.mjs"
    ]
  },
  "environment": {
    "context": ".",
    "dockerfile": ".agentic-delivery/Dockerfile",
    "network": "egress",
    "pids_limit": 512,
    "memory": "4G",
    "cpus": "2"
  },
  "commands": [
    {
      "id": "probe_npm_dependencies",
      "argv": ["node", "tools/agentic-delivery/npm-prereq.mjs", "probe"],
      "working_directory": ".",
      "timeout": "PT30S",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "prepare_npm_dependencies",
      "argv": ["node", "tools/agentic-delivery/npm-prereq.mjs", "prepare"],
      "working_directory": ".",
      "timeout": "PT15M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "verify_npm_dependencies",
      "argv": ["node", "tools/agentic-delivery/npm-prereq.mjs", "verify"],
      "working_directory": ".",
      "timeout": "PT30S",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "probe_foundry_e2e",
      "argv": ["node", "tools/agentic-delivery/foundry-prereq.mjs", "probe"],
      "working_directory": ".",
      "timeout": "PT30S",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "prepare_foundry_e2e",
      "argv": ["node", "tools/agentic-delivery/foundry-prereq.mjs", "prepare"],
      "working_directory": ".",
      "timeout": "PT2M",
      "secret_inputs": [
        "foundry_broker_session",
        "foundry_broker_session_v13_351_dnd5e",
        "foundry_broker_session_v13_351_pf2e",
        "foundry_broker_session_v14_364_dnd5e",
        "foundry_broker_session_v14_364_pf2e",
        "foundry_license_key"
      ],
      "resource_inputs": ["foundry_v13_351_zip", "foundry_v14_364_zip"]
    },
    {
      "id": "verify_foundry_e2e",
      "argv": ["node", "tools/agentic-delivery/foundry-prereq.mjs", "verify"],
      "working_directory": ".",
      "timeout": "PT30S",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "cleanup_foundry_e2e",
      "argv": ["node", "tools/agentic-delivery/foundry-prereq.mjs", "cleanup"],
      "working_directory": ".",
      "timeout": "PT30S",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "format_check",
      "argv": ["node", "tools/agentic-delivery/format-check.mjs"],
      "working_directory": ".",
      "timeout": "PT5M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "static_baseline",
      "argv": ["npm", "run", "test:static"],
      "working_directory": ".",
      "timeout": "PT10M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "policy_check",
      "argv": ["npm", "run", "test:policy"],
      "working_directory": ".",
      "timeout": "PT5M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "dead_code_check",
      "argv": ["node", "tools/agentic-delivery/dead-code-check.mjs"],
      "working_directory": ".",
      "timeout": "PT10M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "build_packs",
      "argv": ["npm", "run", "build:packs"],
      "working_directory": ".",
      "timeout": "PT10M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "package_module",
      "argv": ["npm", "run", "package:module"],
      "working_directory": ".",
      "timeout": "PT5M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "package_tests",
      "argv": ["npm", "run", "test:package"],
      "working_directory": ".",
      "timeout": "PT10M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "unit_tests",
      "argv": ["npm", "run", "test:unit"],
      "working_directory": ".",
      "timeout": "PT10M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "regression_tests",
      "argv": ["npm", "run", "test:regression"],
      "working_directory": ".",
      "timeout": "PT10M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "integration_tests",
      "argv": ["npm", "run", "test:integration"],
      "working_directory": ".",
      "timeout": "PT10M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "security_tests",
      "argv": ["npm", "run", "test:security"],
      "working_directory": ".",
      "timeout": "PT10M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "component_tests",
      "argv": ["npm", "run", "test:component"],
      "working_directory": ".",
      "timeout": "PT10M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "ui_tests",
      "argv": ["npm", "run", "test:ui"],
      "working_directory": ".",
      "timeout": "PT1H",
      "secret_inputs": [
        "foundry_broker_session",
        "foundry_broker_session_v13_351_dnd5e",
        "foundry_broker_session_v13_351_pf2e",
        "foundry_broker_session_v14_364_dnd5e",
        "foundry_broker_session_v14_364_pf2e"
      ],
      "resource_inputs": []
    },
    {
      "id": "accessibility_tests",
      "argv": ["npm", "run", "test:accessibility"],
      "working_directory": ".",
      "timeout": "PT1H",
      "secret_inputs": [
        "foundry_broker_session",
        "foundry_broker_session_v13_351_dnd5e",
        "foundry_broker_session_v13_351_pf2e",
        "foundry_broker_session_v14_364_dnd5e",
        "foundry_broker_session_v14_364_pf2e"
      ],
      "resource_inputs": []
    },
    {
      "id": "e2e_tests",
      "argv": ["npm", "run", "test:foundry"],
      "working_directory": ".",
      "timeout": "PT1H",
      "secret_inputs": [
        "foundry_broker_session",
        "foundry_broker_session_v13_351_dnd5e",
        "foundry_broker_session_v13_351_pf2e",
        "foundry_broker_session_v14_364_dnd5e",
        "foundry_broker_session_v14_364_pf2e"
      ],
      "resource_inputs": []
    }
  ],
  "prerequisites": [
    {
      "id": "npm_dependencies",
      "owner": "repository",
      "description": "Restores root npm dependencies from an Agentic Delivery image cache into the mounted workspace, falling back to npm ci only when the cache is unavailable, so repository npm commands remain reproducible after the worker mount hides image-layer node_modules.",
      "probe_command": "probe_npm_dependencies",
      "prepare_command": "prepare_npm_dependencies",
      "verify_command": "verify_npm_dependencies",
      "cleanup_command": null,
      "external_input": null
    },
    {
      "id": "foundry_e2e_inputs",
      "owner": "repository",
      "description": "Prepares the Playwright Foundry harness from matrix-scoped broker sessions that match each selected Foundry version and game system, while retaining the repository-owned licensed local setup inputs.",
      "probe_command": "probe_foundry_e2e",
      "prepare_command": "prepare_foundry_e2e",
      "verify_command": "verify_foundry_e2e",
      "cleanup_command": "cleanup_foundry_e2e",
      "external_input": null
    }
  ],
  "validations": [
    {
      "id": "build_validation",
      "category": "build",
      "applicable": true,
      "rationale": "The repository checks in the built compendium LevelDB output under packs/ and validates the distributable artifact by packaging the module zip plus running the package smoke test that inspects the built archive contents.",
      "command_ids": ["package_module", "package_tests"],
      "prerequisite_ids": ["npm_dependencies"],
      "artifact_ids": ["dist_zip"],
      "matrix": [
        {
          "name": "node_version",
          "values": ["24"]
        }
      ]
    },
    {
      "id": "lint_validation",
      "category": "lint",
      "applicable": true,
      "rationale": "The repository checks in tests/baselines/eslint.json and exposes npm run test:static as the reproducible ESLint clean gate; CI only promotes ordinary pull requests to a full npm run lint:check when lint configuration changes.",
      "command_ids": ["static_baseline"],
      "prerequisite_ids": ["npm_dependencies"],
      "artifact_ids": [],
      "matrix": [
        {
          "name": "node_version",
          "values": ["24"]
        }
      ]
    },
    {
      "id": "format_validation",
      "category": "format",
      "applicable": true,
      "rationale": "CI only promotes formatter changes to a full npm run format:check when Prettier-related config changes; otherwise it runs Prettier on the changed files, so the repository-owned format gate mirrors that changed-file policy.",
      "command_ids": ["format_check"],
      "prerequisite_ids": ["npm_dependencies"],
      "artifact_ids": [],
      "matrix": [
        {
          "name": "node_version",
          "values": ["24"]
        }
      ]
    },
    {
      "id": "static_analysis_validation",
      "category": "static_analysis",
      "applicable": true,
      "rationale": "The repository maintains a required test policy check and a dead-code gate, but CI only promotes dead-code analysis to a full raw knip run when lint or knip configuration changes; otherwise it diffs knip findings against the base revision so pre-existing baseline findings do not fail clean repository validation.",
      "command_ids": ["policy_check", "dead_code_check"],
      "prerequisite_ids": ["npm_dependencies"],
      "artifact_ids": [],
      "matrix": [
        {
          "name": "node_version",
          "values": ["24"]
        }
      ]
    },
    {
      "id": "unit_validation",
      "category": "unit",
      "applicable": true,
      "rationale": "tests/unit contains node:test suites and package.json exposes npm run test:unit through the shared tier runner.",
      "command_ids": ["unit_tests"],
      "prerequisite_ids": ["npm_dependencies"],
      "artifact_ids": [],
      "matrix": [
        {
          "name": "node_version",
          "values": ["24"]
        }
      ]
    },
    {
      "id": "regression_validation",
      "category": "regression",
      "applicable": true,
      "rationale": "tests/regression and the compaction budget script are wired to npm run test:regression in the repository tier runner.",
      "command_ids": ["regression_tests"],
      "prerequisite_ids": ["npm_dependencies"],
      "artifact_ids": [],
      "matrix": [
        {
          "name": "node_version",
          "values": ["24"]
        }
      ]
    },
    {
      "id": "integration_validation",
      "category": "integration",
      "applicable": true,
      "rationale": "tests/integration/local contains repository-owned integration checks and npm run test:integration targets that local suite without requiring external provider credentials.",
      "command_ids": ["integration_tests"],
      "prerequisite_ids": ["npm_dependencies"],
      "artifact_ids": [],
      "matrix": [
        {
          "name": "node_version",
          "values": ["24"]
        }
      ]
    },
    {
      "id": "security_validation",
      "category": "security",
      "applicable": true,
      "rationale": "tests/security contains sanitizer and secret-scanning assertions, and package.json exposes npm run test:security for that suite.",
      "command_ids": ["security_tests"],
      "prerequisite_ids": ["npm_dependencies"],
      "artifact_ids": [],
      "matrix": [
        {
          "name": "node_version",
          "values": ["24"]
        }
      ]
    },
    {
      "id": "accessibility_validation",
      "category": "accessibility",
      "applicable": true,
      "rationale": "tests/e2e/specs/common/accessibility.spec.mjs is tagged @accessibility, package.json defines npm run test:accessibility through the shared tier runner, and the Playwright harness retains screenshot, video, trace, console, DOM, and accessibility evidence for each browser validation.",
      "command_ids": ["accessibility_tests"],
      "prerequisite_ids": ["npm_dependencies", "foundry_e2e_inputs"],
      "artifact_ids": [
        "browser_screenshots",
        "browser_video",
        "browser_trace",
        "browser_console",
        "browser_dom",
        "browser_accessibility"
      ],
      "matrix": [
        {
          "name": "node_version",
          "values": ["24"]
        },
        {
          "name": "browser",
          "values": ["chromium"]
        },
        {
          "name": "foundry_version",
          "values": ["13.351", "14.364"]
        },
        {
          "name": "game_system",
          "values": ["dnd5e", "pf2e"]
        }
      ]
    },
    {
      "id": "component_validation",
      "category": "component",
      "applicable": true,
      "rationale": "tests/component contains focused node:test coverage for the sidebar template and package.json exposes npm run test:component for that tier.",
      "command_ids": ["component_tests"],
      "prerequisite_ids": ["npm_dependencies"],
      "artifact_ids": [],
      "matrix": [
        {
          "name": "node_version",
          "values": ["24"]
        }
      ]
    },
    {
      "id": "ui_validation",
      "category": "ui",
      "applicable": true,
      "rationale": "tests/e2e/specs/common/sidebar.spec.mjs is tagged @ui, package.json defines npm run test:ui through the shared tier runner, and the Playwright harness retains screenshot, video, trace, console, DOM, and accessibility evidence for each browser validation.",
      "command_ids": ["ui_tests"],
      "prerequisite_ids": ["npm_dependencies", "foundry_e2e_inputs"],
      "artifact_ids": [
        "browser_screenshots",
        "browser_video",
        "browser_trace",
        "browser_console",
        "browser_dom",
        "browser_accessibility"
      ],
      "matrix": [
        {
          "name": "node_version",
          "values": ["24"]
        },
        {
          "name": "browser",
          "values": ["chromium"]
        },
        {
          "name": "foundry_version",
          "values": ["13.351", "14.364"]
        },
        {
          "name": "game_system",
          "values": ["dnd5e", "pf2e"]
        }
      ]
    },
    {
      "id": "e2e_validation",
      "category": "e2e",
      "applicable": true,
      "rationale": "npm run test:foundry executes the complete Playwright Foundry suite across the documented default Foundry version and game-system matrix, and the Playwright harness retains screenshot, video, trace, console, DOM, and accessibility evidence for each browser validation.",
      "command_ids": ["e2e_tests"],
      "prerequisite_ids": ["npm_dependencies", "foundry_e2e_inputs"],
      "artifact_ids": [
        "browser_screenshots",
        "browser_video",
        "browser_trace",
        "browser_console",
        "browser_dom",
        "browser_accessibility"
      ],
      "matrix": [
        {
          "name": "node_version",
          "values": ["24"]
        },
        {
          "name": "browser",
          "values": ["chromium"]
        },
        {
          "name": "foundry_version",
          "values": ["13.351", "14.364"]
        },
        {
          "name": "game_system",
          "values": ["dnd5e", "pf2e"]
        }
      ]
    }
  ],
  "artifacts": [
    {
      "id": "dist_zip",
      "path_pattern": "dist/*.zip",
      "required": true
    },
    {
      "id": "browser_screenshots",
      "path_pattern": "tests/e2e/test-results/screenshots/*",
      "required": true
    },
    {
      "id": "browser_video",
      "path_pattern": "tests/e2e/test-results/video/*",
      "required": true
    },
    {
      "id": "browser_trace",
      "path_pattern": "tests/e2e/test-results/trace/*",
      "required": true
    },
    {
      "id": "browser_console",
      "path_pattern": "tests/e2e/test-results/console/*",
      "required": true
    },
    {
      "id": "browser_dom",
      "path_pattern": "tests/e2e/test-results/dom/*",
      "required": true
    },
    {
      "id": "browser_accessibility",
      "path_pattern": "tests/e2e/test-results/accessibility/*",
      "required": true
    }
  ],
  "external_inputs": [
    {
      "id": "foundry_broker_session",
      "kind": "secret",
      "purpose": "Fallback scoped Foundry broker session JSON whose logs_url anchors the provider endpoint and whose credentials authorize repository-owned Playwright evidence collection."
    },
    {
      "id": "foundry_broker_session_v13_351_dnd5e",
      "kind": "secret",
      "purpose": "Scoped Foundry broker session JSON for the chromium / Foundry 13.351 / dnd5e matrix member, whose logs_url anchors the provider endpoint and whose credentials authorize repository-owned Playwright evidence collection."
    },
    {
      "id": "foundry_broker_session_v13_351_pf2e",
      "kind": "secret",
      "purpose": "Scoped Foundry broker session JSON for the chromium / Foundry 13.351 / pf2e matrix member, whose logs_url anchors the provider endpoint and whose credentials authorize repository-owned Playwright evidence collection."
    },
    {
      "id": "foundry_broker_session_v14_364_dnd5e",
      "kind": "secret",
      "purpose": "Scoped Foundry broker session JSON for the chromium / Foundry 14.364 / dnd5e matrix member, whose logs_url anchors the provider endpoint and whose credentials authorize repository-owned Playwright evidence collection."
    },
    {
      "id": "foundry_broker_session_v14_364_pf2e",
      "kind": "secret",
      "purpose": "Scoped Foundry broker session JSON for the chromium / Foundry 14.364 / pf2e matrix member, whose logs_url anchors the provider endpoint and whose credentials authorize repository-owned Playwright evidence collection."
    },
    {
      "id": "foundry_license_key",
      "kind": "license",
      "purpose": "Licensed Foundry VTT key used by the repository-owned local harness when broker sessions are not supplied."
    },
    {
      "id": "foundry_v13_351_zip",
      "kind": "resource",
      "purpose": "Licensed Foundry VTT 13.351 Node distribution zip consumed by the repository-owned local harness for the supported Foundry 13 matrix member."
    },
    {
      "id": "foundry_v14_364_zip",
      "kind": "resource",
      "purpose": "Licensed Foundry VTT 14.364 Node distribution zip consumed by the repository-owned local harness for the supported Foundry 14 matrix member."
    }
  ]
}
