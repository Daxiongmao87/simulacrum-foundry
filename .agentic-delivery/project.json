{
  "schema_version": "v1",
  "project": {
    "key": "simulacrum",
    "display_name": "Simulacrum: AI Campaign Copilot",
    "base_branch": "main"
  },
  "pipeline": {
    "trigger_labels": [
      "agentic-delivery"
    ],
    "human_authority": "Daxiongmao87",
    "models": {
      "default": "gpt-5.4",
      "roles": []
    },
    "protected_paths": [
      ".github/workflows",
      "CHANGELOG.md",
      "module.json",
      ".agentic-delivery/project.json"
    ]
  },
  "environment": {
    "context": ".",
    "dockerfile": ".agentic-delivery/Dockerfile",
    "network": "egress",
    "pids_limit": 512,
    "memory": "4G",
    "cpus": "2"
  },
  "commands": [
    {
      "id": "probe_npm_dependencies",
      "argv": [
        "node",
        "tools/agentic-delivery/npm-prereq.mjs",
        "probe"
      ],
      "working_directory": ".",
      "timeout": "PT30S",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "prepare_npm_dependencies",
      "argv": [
        "node",
        "tools/agentic-delivery/npm-prereq.mjs",
        "prepare"
      ],
      "working_directory": ".",
      "timeout": "PT15M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "verify_npm_dependencies",
      "argv": [
        "node",
        "tools/agentic-delivery/npm-prereq.mjs",
        "verify"
      ],
      "working_directory": ".",
      "timeout": "PT30S",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "probe_foundry_e2e",
      "argv": [
        "node",
        "tools/agentic-delivery/foundry-prereq.mjs",
        "probe"
      ],
      "working_directory": ".",
      "timeout": "PT30S",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "prepare_foundry_e2e",
      "argv": [
        "node",
        "tools/agentic-delivery/foundry-prereq.mjs",
        "prepare"
      ],
      "working_directory": ".",
      "timeout": "PT2M",
      "secret_inputs": [
        "foundry_license_key"
      ],
      "resource_inputs": [
        "foundry_v13_351_zip",
        "foundry_v14_364_zip"
      ]
    },
    {
      "id": "verify_foundry_e2e",
      "argv": [
        "node",
        "tools/agentic-delivery/foundry-prereq.mjs",
        "verify"
      ],
      "working_directory": ".",
      "timeout": "PT30S",
      "secret_inputs": [
        "foundry_license_key"
      ],
      "resource_inputs": [
        "foundry_v13_351_zip",
        "foundry_v14_364_zip"
      ]
    },
    {
      "id": "cleanup_foundry_e2e",
      "argv": [
        "node",
        "tools/agentic-delivery/foundry-prereq.mjs",
        "cleanup"
      ],
      "working_directory": ".",
      "timeout": "PT30S",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "lint_check",
