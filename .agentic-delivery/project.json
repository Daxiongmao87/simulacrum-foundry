  "prerequisites": [
    {
      "id": "npm_dependencies",
      "owner": "repository",
      "description": "Restores root npm dependencies from an Agentic Delivery image cache into the mounted workspace, falling back to npm ci only when the cache is unavailable, so repository npm commands remain reproducible after the worker mount hides image-layer node_modules.",
      "probe_command": "probe_npm_dependencies",
      "prepare_command": "prepare_npm_dependencies",
      "verify_command": "verify_npm_dependencies",
      "cleanup_command": null,
      "external_input": null
    },
    {
      "id": "foundry_e2e_inputs",
      "owner": "repository",
      "description": "Maps Agentic Delivery Foundry license and per-version zip resources into the repository paths expected by the Playwright Foundry harness.",
      "probe_command": "probe_foundry_e2e",
      "prepare_command": "prepare_foundry_e2e",
      "verify_command": "verify_foundry_e2e",
      "cleanup_command": "cleanup_foundry_e2e",
      "external_input": "foundry_license_key"
    }
  ],
  "validations": [
    {
      "id": "build_validation",
      "category": "build",
      "applicable": true,
      "rationale": "The repository checks in the built compendium LevelDB output under packs/ and validates the distributable artifact by packaging the module zip plus running the package smoke test that inspects the built archive contents.",
      "command_ids": [
        "package_module",
        "package_tests"
      ],
      "prerequisite_ids": [
        "npm_dependencies"
      ],
      "artifact_ids": [
        "dist_zip"
      ],
      "matrix": [
        {
          "name": "node_version",
          "values": [
            "24"
          ]
        }
      ]
    },
    {
      "id": "lint_validation",
      "category": "lint",
      "applicable": true,
      "rationale": "CI runs ESLint, and the repository exposes npm run lint:check as the authoritative lint command.",
