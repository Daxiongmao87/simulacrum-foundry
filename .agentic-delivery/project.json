  "artifacts": [
    {
      "id": "dist_zip",
      "path_pattern": "dist/*.zip",
      "required": true
    }
  ],
  "external_inputs": [
    {
      "id": "foundry_license_key",
      "kind": "license",
      "purpose": "Single-line licensed Foundry VTT key used to sign the local test instance during Playwright Foundry validation."
    },
    {
      "id": "foundry_v13_351_zip",
      "kind": "resource",
      "purpose": "Licensed Foundry VTT Node distribution zip for version 13.351, mounted so the repository harness can materialize the v13 Playwright test instance."
    },
    {
      "id": "foundry_v14_364_zip",
      "kind": "resource",
      "purpose": "Licensed Foundry VTT Node distribution zip for version 14.364, mounted so the repository harness can materialize the v14 Playwright test instance."
    }
  ]
