        "npm",
        "run",
        "lint:check"
      ],
      "working_directory": ".",
      "timeout": "PT5M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "format_check",
      "argv": [
        "npm",
        "run",
        "format:check"
      ],
      "working_directory": ".",
      "timeout": "PT5M",
      "secret_inputs": [],
      "resource_inputs": []
    },
    {
      "id": "static_baseline",
      "argv": [
        "npm",
