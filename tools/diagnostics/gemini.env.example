# Gemini OpenAI-compatible endpoint diagnostic configuration
# Copy this file to .env.gemini in this directory and fill in your API key.

# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Optional: specify a different model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-pro
