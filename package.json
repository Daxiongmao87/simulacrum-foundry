{
  "name": "simulacrum-foudry",
  "version": "1.0.0",
  "type": "module",
  "description": "🤖 **A comprehensive AI-powered campaign assistant for FoundryVTT v12 Game Masters and Assistant GMs**",
  "main": "scripts/main.js",
  "scripts": {
    "test": "node tests/run-tests.js",
    "test:unit": "node tests/run-tests.js",
    "test:unit:v13": "node tests/run-tests.js -v v13",
    "test:unit:coverage": "node tests/run-tests.js --coverage",
    "test:coverage": "node tests/run-tests.js --coverage --unit",
    "coverage:report": "node tests/run-tests.js --coverage --unit --html",
    "coverage:static": "node tools/static-analysis-coverage.js",
    "coverage:static:verbose": "node tools/static-analysis-coverage.js --verbose",
    "coverage:check": "node tools/static-analysis-coverage.js --threshold=95",
    "test:list": "node tests/run-tests.js --list-tests",
    "launch:foundry": "node tests/launch-foundry.js",
    "launch:foundry:debug": "node tests/launch-foundry.js --debug",
    "lint": "eslint scripts/**/*.js",
    "lint:fix": "eslint scripts/**/*.js --fix",
    "lint:strict": "eslint scripts/**/*.js --max-warnings 0",
    "format": "prettier --write scripts/**/*.js",
    "quality:check": "npm run lint",
    "package": "node tools/package-module.js",
    "copy-to-docker": "node tools/copy-to-docker.js",
    "deploy": "node tools/deploy-to-test-containers.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "scripts/**/*.js": [
      "eslint --fix --max-warnings 250",
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/preset-env": "^7.28.0",
    "eslint": "^9.33.0",
    "glob": "^10.3.0",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "puppeteer": "^22.0.0"
  }
}
