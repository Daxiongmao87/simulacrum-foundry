{
  "name": "simulacrum",
  "version": "1.0.1",
  "type": "module",
  "description": "An AI-powered assistant for FoundryVTT campaign document management",
  "main": "scripts/simulacrum.js",
  "scripts": {
    "lint": "eslint scripts/ --fix",
    "lint:check": "eslint scripts/",
    "lint:json": "eslint . --ext .json --fix",
    "lint:json:check": "eslint . --ext .json",
    "format": "prettier --write scripts/ *.json *.md",
    "format:check": "prettier --check scripts/ *.json *.md",
    "package:module": "node tools/package-module.js",
    "build:packs": "node tools/build-packs.js",
    "dead-code": "knip",
    "dead-code:fix": "knip --fix",
    "unused": "unimported",
    "test:policy": "node tools/test-tier-runner.mjs policy",
    "test:static": "node tools/test-tier-runner.mjs static",
    "test:unit": "node tools/test-tier-runner.mjs unit",
    "test:regression": "node tools/test-tier-runner.mjs regression",
    "test:integration": "node tools/test-tier-runner.mjs integration",
    "test:component": "node tools/test-tier-runner.mjs component",
    "test:security": "node tools/test-tier-runner.mjs security",
    "test:package": "node tools/test-tier-runner.mjs package",
    "test:ui": "node tools/test-tier-runner.mjs ui",
    "test:accessibility": "node tools/test-tier-runner.mjs accessibility",
    "test:foundry:smoke": "node tools/test-tier-runner.mjs foundry-smoke",
    "test:foundry": "node tools/test-tier-runner.mjs foundry",
    "test:local": "npm run test:policy && npm run test:static && npm run test:unit && npm run test:regression && npm run test:integration && npm run test:component && npm run test:security && npm run test:package",
    "test:repair": "node tests/utils/test-repair.mjs",
    "diagnostic:gemini": "node tools/diagnostics/gemini-openai.mjs",
    "test:e2e": "npm run test:foundry",
    "test:e2e:ui": "playwright test --config=tests/e2e/playwright.config.mjs --ui",
    "test:e2e:headed": "playwright test --config=tests/e2e/playwright.config.mjs --headed",
    "test:e2e:debug": "playwright test --config=tests/e2e/playwright.config.mjs --debug",
    "test:changelog": "node tests/utils/test-generate-unreleased-changelog.mjs",
    "test:foundry-release": "node tests/utils/test-foundry-release.mjs"
  },
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^3.0.2",
    "@playwright/test": "^1.60.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^29.12.1",
    "eslint-plugin-jsonc": "^2.20.1",
    "knip": "^5.0.0",
    "prettier": "^3.2.0",
    "unimported": "^1.31.0"
  },
  "keywords": [
    "foundryvtt",
    "ai",
    "assistant",
    "campaign",
    "documents"
  ],
  "author": "Daxiongmao87",
  "license": "MIT"
}
