# =============================================================================
# Simulacrum E2E Test Configuration
# =============================================================================
# Copy this file to .env.test and fill in your values.
# .env.test is gitignored -- never commit it.
# =============================================================================

# -----------------------------------------------------------------------------
# Foundry VTT Configuration
# -----------------------------------------------------------------------------

# Admin password used for all test instances.
FOUNDRY_ADMIN_KEY=test-admin-password

# License resolution (pick one, or rely on auto-detection):
#
#   Auto (default): if you have launched Foundry locally the suite finds
#   license.json at the OS default path automatically -- nothing to set.
#
#   Explicit file path:
# FOUNDRY_LICENSE_JSON_PATH=C:\Users\You\AppData\Local\FoundryVTT\Config\license.json
#
#   Base64-encoded content (CI / container use -- set by run-in-container.js
#   automatically from the host license, or provided as a CI secret):
# FOUNDRY_LICENSE_JSON_B64=<base64>
#
#   Legacy key fallback (only if none of the above resolve a license.json):
# FOUNDRY_LICENSE_KEY=XXXX-XXXX-XXXX-XXXX-XXXX

# Set to any non-empty value to stream Foundry server stdout/stderr to console.
# DEBUG_FOUNDRY=1

# -----------------------------------------------------------------------------
# Game System Configuration
# -----------------------------------------------------------------------------

# Comma-separated list of Foundry package IDs to test against.
# Tests run against EACH system listed. System files are cached after the first
# run so subsequent runs skip the download.
#
# Examples:
#   TEST_SYSTEM_IDS=dnd5e
#   TEST_SYSTEM_IDS=dnd5e,pf2e
TEST_SYSTEM_IDS=dnd5e

# -----------------------------------------------------------------------------
# Container / CI mode (set automatically by run-in-container.js)
# -----------------------------------------------------------------------------

# Path to a pre-extracted Foundry installation (e.g. inside a felddy container).
# When set, zip discovery and extraction are skipped entirely.
# FOUNDRY_INSTALL_PATH=/home/node/resources/app
