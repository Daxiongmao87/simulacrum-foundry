# =============================================================================
# Simulacrum E2E Test Configuration
# =============================================================================
# Copy this file to .env.test and fill in your values.
# .env.test is gitignored -- never commit it.
# =============================================================================

# -----------------------------------------------------------------------------
# Foundry VTT Configuration
# -----------------------------------------------------------------------------

# Admin password used for all test instances.
FOUNDRY_ADMIN_KEY=test-admin-password

# License key -- only needed if license.json cannot be auto-resolved from a
# local Foundry install. The suite looks for license.json at the standard OS
# path (%LOCALAPPDATA%\FoundryVTT\Config\license.json on Windows, etc.).
# If your file is elsewhere, set FOUNDRY_LICENSE_JSON_PATH instead.
# FOUNDRY_LICENSE_KEY=XXXX-XXXX-XXXX-XXXX-XXXX

# Explicit path to license.json (overrides auto-resolution).
# FOUNDRY_LICENSE_JSON_PATH=C:\Users\You\AppData\Local\FoundryVTT\Config\license.json

# Set to any non-empty value to stream Foundry server stdout/stderr to console.
# DEBUG_FOUNDRY=1

# -----------------------------------------------------------------------------
# Game System Configuration
# -----------------------------------------------------------------------------

# Comma-separated list of Foundry package IDs to test against.
# Tests run against EACH system listed. System files are cached after the first
# run so subsequent runs skip the download.
#
# Examples:
#   TEST_SYSTEM_IDS=dnd5e
#   TEST_SYSTEM_IDS=dnd5e,pf2e
TEST_SYSTEM_IDS=dnd5e
